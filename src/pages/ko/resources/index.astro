---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allResources = await getCollection('resources');
const koResources = allResources.filter((r) => r.data.lang === 'ko');
const resources = koResources.length > 0
  ? koResources.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  : allResources.filter((r) => r.data.lang === 'en').sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
const showingEnglish = koResources.length === 0;

const alternates = [
  { lang: 'en', href: 'https://apls.kr/resources' },
  { lang: 'ko', href: 'https://apls.kr/ko/resources' },
  { lang: 'ja', href: 'https://apls.kr/ja/resources' },
  { lang: 'zh', href: 'https://apls.kr/zh/resources' },
];

const categoryLabels: Record<string, string> = {
  method: '진단 방법론',
  science: '색채 과학',
  industry: '업계 & 자격',
  'case-study': '진단 사례',
};
---

<BaseLayout
  title="자료실 — 퍼스널컬러 과학 & 업계 인사이트 | APL Color"
  description="퍼스널컬러 진단 방법론, LAB 분광측색 과학, 업계 자격증, 진단 사례 연구 — APL Color 13,000건 이상의 진단 데이터 기반 전문 아티클."
  lang="ko"
  alternates={alternates}
>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', 'Noto Sans KR', sans-serif; background: #FAF8F5; color: #1a1a1a; }
    .nav { display: flex; justify-content: space-between; align-items: center; padding: 1.5rem 5%; border-bottom: 1px solid #e8e0d8; background: #FAF8F5; position: sticky; top: 0; z-index: 100; }
    .nav-brand { font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; font-weight: 600; color: #1a1a1a; text-decoration: none; }
    .nav-links { display: flex; gap: 2rem; align-items: center; }
    .nav-links a { font-size: 0.85rem; font-weight: 500; color: #555; text-decoration: none; letter-spacing: 0.05em; text-transform: uppercase; }
    .nav-links a:hover { color: #1a1a1a; }
    .lang-switch { display: flex; gap: 0.5rem; margin-left: 1.5rem; padding-left: 1.5rem; border-left: 1px solid #e8e0d8; }
    .lang-switch a { font-size: 0.75rem; padding: 0.25rem 0.5rem; border: 1px solid #e8e0d8; border-radius: 3px; text-decoration: none; color: #888; }
    .lang-switch a:hover, .lang-switch a.active { color: #1a1a1a; border-color: #1a1a1a; }
    .hero { padding: 5rem 5% 3rem; max-width: 900px; margin: 0 auto; text-align: center; }
    .hero h1 { font-family: 'Cormorant Garamond', serif; font-size: 2.8rem; font-weight: 400; margin-bottom: 1rem; line-height: 1.2; }
    .hero p { font-size: 1.05rem; color: #666; line-height: 1.7; max-width: 650px; margin: 0 auto; }
    .en-notice { text-align: center; padding: 1rem 5%; }
    .en-notice p { font-size: 0.85rem; color: #8B7355; background: #f0ebe4; display: inline-block; padding: 0.5rem 1.5rem; border-radius: 4px; }
    .articles { max-width: 900px; margin: 0 auto; padding: 2rem 5% 5rem; }
    .article-card { border-bottom: 1px solid #e8e0d8; padding: 2.5rem 0; }
    .article-card:first-child { padding-top: 0; }
    .article-meta { display: flex; gap: 1rem; align-items: center; margin-bottom: 0.75rem; }
    .article-category { font-size: 0.7rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #8B7355; }
    .article-date { font-size: 0.75rem; color: #999; }
    .article-card h2 { font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; font-weight: 500; margin-bottom: 0.75rem; line-height: 1.3; }
    .article-card h2 a { color: #1a1a1a; text-decoration: none; }
    .article-card h2 a:hover { color: #8B7355; }
    .article-desc { font-size: 0.95rem; color: #666; line-height: 1.7; margin-bottom: 1rem; }
    .read-more { font-size: 0.8rem; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; color: #8B7355; text-decoration: none; }
    .read-more:hover { color: #1a1a1a; }
    .keywords { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-bottom: 0.75rem; }
    .keyword { font-size: 0.65rem; padding: 0.2rem 0.6rem; background: #f0ebe4; border-radius: 10px; color: #8B7355; }
    .cta-section { background: #1a1a1a; color: #FAF8F5; padding: 4rem 5%; text-align: center; }
    .cta-section h2 { font-family: 'Cormorant Garamond', serif; font-size: 2rem; font-weight: 400; margin-bottom: 1rem; }
    .cta-section p { font-size: 0.95rem; color: #aaa; margin-bottom: 2rem; }
    .cta-btn { display: inline-block; padding: 1rem 2.5rem; border: 1px solid #FAF8F5; color: #FAF8F5; text-decoration: none; font-size: 0.85rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; transition: all 0.3s; }
    .cta-btn:hover { background: #FAF8F5; color: #1a1a1a; }
    .footer { padding: 3rem 5%; text-align: center; font-size: 0.8rem; color: #999; border-top: 1px solid #e8e0d8; }
    @media (max-width: 768px) { .hero h1 { font-size: 2rem; } .nav-links { display: none; } .article-card h2 { font-size: 1.3rem; } }
  </style>

  <nav class="nav">
    <a href="/ko" class="nav-brand">APL Color</a>
    <div class="nav-links">
      <a href="/ko/professional-course">과정 안내</a>
      <a href="/ko/resources">자료실</a>
      <div class="lang-switch">
        <a href="/resources">EN</a>
        <a href="/ko/resources" class="active">KO</a>
        <a href="/ja/resources">JA</a>
        <a href="/zh/resources">ZH</a>
      </div>
    </div>
  </nav>

  <section class="hero">
    <h1>자료실</h1>
    <p>퍼스널컬러 진단 방법론, 색채 과학, 업계 자격증 정보, 진단 사례 연구 — 국가공인 컬러리스트기사 전문가 팀이 작성한 전문 아티클.</p>
  </section>

  {showingEnglish && (
    <div class="en-notice">
      <p>현재 영문 콘텐츠를 표시하고 있습니다. 한국어 아티클이 곧 추가됩니다.</p>
    </div>
  )}

  <section class="articles">
    {resources.map((resource) => (
      <article class="article-card">
        <div class="article-meta">
          <span class="article-category">{categoryLabels[resource.data.category] || resource.data.category}</span>
          <span class="article-date">{resource.data.publishDate.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
        </div>
        <h2><a href={`/resources/${resource.id}`}>{resource.data.title}</a></h2>
        <p class="article-desc">{resource.data.description}</p>
        <div class="keywords">
          {resource.data.keywords.slice(0, 4).map((kw) => (
            <span class="keyword">{kw}</span>
          ))}
        </div>
        <a href={`/resources/${resource.id}`} class="read-more">자세히 보기 →</a>
      </article>
    ))}
  </section>

  <section class="cta-section">
    <h2>전문가 과정 수강하기</h2>
    <p>국가공인 컬러리스트기사 강사진의 4일 집중 전문가 과정</p>
    <a href="/ko/professional-course" class="cta-btn">과정 상세보기</a>
  </section>

  <footer class="footer">
    <p>&copy; 2025 APL Color. All rights reserved.</p>
  </footer>
</BaseLayout>
