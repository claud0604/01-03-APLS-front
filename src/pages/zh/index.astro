---
import BaseLayout from '../../layouts/BaseLayout.astro';

const alternates = [
  { lang: 'en', href: 'https://apls.kr/' },
  { lang: 'ko', href: 'https://apls.kr/ko/' },
  { lang: 'ja', href: 'https://apls.kr/ja/' },
  { lang: 'zh', href: 'https://apls.kr/zh/' },
];

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "APL Color",
  "url": "https://apls.kr",
  "description": "韩国釜山专业个人色彩分析与培训公司。由国家认证色彩师技师资格讲师运营，在釜山、首尔、大阪、上海设有工作室。",
  "sameAs": ["https://www.instagram.com/aplcolor_official/", "https://kcfb.kr"]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "APL的诊断与其他有何不同？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "APL使用LS170分光测色仪进行LAB色空间测色诊断。不仅依靠主观的披肩法，还基于13,000多件科学数据提供客观诊断。"
      }
    },
    {
      "@type": "Question",
      "name": "在韩国以外也能接受服务吗？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "是的。我们在釜山、首尔、大阪、上海4个城市运营工作室，提供韩语、英语、日语、中文4种语言的服务。"
      }
    },
    {
      "@type": "Question",
      "name": "需要什么前提条件才能参加专业课程？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "无需前提条件。4天的集中专业课程面向初学者和有经验的专业人士。由持有国家认证色彩师技师资格的讲师亲自授课。"
      }
    }
  ]
};

const schemas = [organizationSchema, faqSchema];
---

<BaseLayout
  title="APL Color — 专业个人色彩分析与培训 | 韩国釜山"
  description="APL Color是韩国釜山专业个人色彩培训项目。国家认证色彩师技师讲师团队，LS170分光测色仪LAB诊断，釜山·首尔·大阪·上海4城运营。"
  lang="zh"
  alternates={alternates}
  schema={schemas}
>

<style>
:root {
  --bg: #ece0c8; --bg-white: #FFFFFF; --text: #222222; --text-sub: #888888; --text-dim: #AAAAAA; --border: #E5E5E5;
  --font: "Inter", "Noto Sans KR", -apple-system, BlinkMacSystemFont, sans-serif;
  --header-h: 54px; --pad: clamp(20px, 4vw, 52px); --max-w: 1816px;
  --ease: cubic-bezier(.165, .84, .44, 1); --dur: 0.5s; --dur-fast: 0.3s;
}
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { font-size: 16px; -webkit-font-smoothing: antialiased; scroll-behavior: smooth; }
body { font-family: var(--font); color: var(--text); background: var(--bg); line-height: 1.5; overflow-x: hidden; }
a { color: inherit; text-decoration: none; }
button { font: inherit; cursor: pointer; border: none; background: none; }

.header { position: fixed; top: 0; left: 0; right: 0; z-index: 100; height: var(--header-h); display: flex; align-items: center; background: transparent; transition: background var(--dur) var(--ease); }
.header--scrolled { background: rgba(236, 224, 200, 0.92); backdrop-filter: blur(16px); border-bottom: 1px solid var(--border); }
.header__inner { width: 100%; max-width: var(--max-w); margin: 0 auto; padding: 0 var(--pad); display: flex; align-items: center; justify-content: space-between; }
.header__logo { font-weight: 800; font-size: 18px; }
.header__right { display: flex; align-items: center; gap: 20px; }
.header__lang { display: flex; gap: 6px; font-size: 12px; font-weight: 500; }
.header__lang a { color: var(--text-dim); transition: color var(--dur-fast); }
.header__lang a.is-active { color: var(--text); }
.header__cta { font-size: 12px; font-weight: 600; padding: 8px 18px; border: 1.5px solid var(--text); border-radius: 2px; transition: background var(--dur-fast), color var(--dur-fast); }
.header__cta:hover { background: var(--text); color: var(--bg); }

.hero { position: relative; display: flex; flex-direction: column; justify-content: flex-end; padding: calc(var(--header-h) + 100px) var(--pad) 0; }
.hero__title { font-weight: 500; font-size: clamp(38px, 8.8vw, 160px); line-height: 0.9; letter-spacing: -0.04em; text-transform: uppercase; padding-bottom: clamp(32px, 4vw, 60px); }
.hero__definition { font-size: clamp(15px, 1.2vw, 18px); line-height: 1.7; color: var(--text-sub); max-width: 720px; padding: 0 var(--pad) clamp(40px, 6vw, 80px); }

.section { padding: clamp(60px, 10vw, 160px) 0; }
.container { width: 100%; max-width: var(--max-w); margin: 0 auto; padding: 0 var(--pad); }
.section__eyebrow { font-weight: 500; font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-dim); margin-bottom: 32px; display: flex; align-items: center; gap: 16px; }
.section__eyebrow-line { flex: 1; height: 1px; background: var(--border); }
.section__title { font-weight: 800; font-size: clamp(28px, 4.5vw, 64px); line-height: 1.05; letter-spacing: -0.03em; margin-bottom: clamp(32px, 4vw, 64px); }

.about__grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(40px, 6vw, 120px); align-items: start; }
.about__mission { font-weight: 700; font-size: clamp(24px, 3.5vw, 52px); line-height: 1.1; }
.about__desc { font-size: clamp(14px, 1.1vw, 17px); line-height: 1.75; color: var(--text-sub); margin-bottom: 48px; }
.about__stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; padding-top: 40px; border-top: 1px solid var(--border); }
.stat__num { font-weight: 800; font-size: clamp(24px, 2.5vw, 42px); line-height: 1; margin-bottom: 6px; }
.stat__label { font-weight: 600; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-dim); margin-bottom: 2px; }
.stat__sub { font-size: 11px; color: var(--text-dim); line-height: 1.4; }

.faq__list { max-width: 760px; }
.faq__item { border-bottom: 1px solid var(--border); }
.faq__q { width: 100%; display: flex; justify-content: space-between; align-items: center; padding: 20px 0; font-weight: 600; font-size: clamp(14px, 1.1vw, 17px); text-align: left; }
.faq__q:hover { opacity: 0.5; }
.faq__icon { font-size: 18px; font-weight: 300; flex-shrink: 0; margin-left: 20px; transition: transform var(--dur-fast) var(--ease); }
.faq__item.is-open .faq__icon { transform: rotate(45deg); }
.faq__a { max-height: 0; overflow: hidden; transition: max-height 0.6s var(--ease); }
.faq__a-inner { padding-bottom: 20px; font-size: 13px; line-height: 1.7; color: var(--text-sub); max-width: 600px; }

.footer { border-top: 1px solid var(--border); padding: 64px 0 48px; }
.footer__grid { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 48px; margin-bottom: 64px; }
.footer__brand { font-weight: 800; font-size: 18px; margin-bottom: 12px; }
.footer__slogan { font-size: 13px; line-height: 1.5; color: var(--text-sub); }
.footer__col-title { font-weight: 600; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-dim); margin-bottom: 14px; }
.footer__links { display: flex; flex-direction: column; gap: 8px; }
.footer__link { font-size: 13px; color: var(--text-sub); transition: color var(--dur-fast); }
.footer__link:hover { color: var(--text); }
.footer__bottom { display: flex; justify-content: space-between; align-items: center; padding-top: 40px; border-top: 1px solid var(--border); }
.footer__legal { font-size: 11px; color: var(--text-dim); line-height: 1.6; }
.footer__lang { display: flex; gap: 10px; }
.footer__lang a { font-size: 11px; font-weight: 600; color: var(--text-dim); }
.footer__lang a.is-active { color: var(--text); }

.reveal { opacity: 0; transform: translateY(16px); transition: opacity 0.7s var(--ease), transform 0.7s var(--ease); }
.reveal.is-visible { opacity: 1; transform: translateY(0); }
.reveal--d1 { transition-delay: 0.1s; }
.reveal--d2 { transition-delay: 0.2s; }

@media (max-width: 1080px) { .about__grid { grid-template-columns: 1fr; } .about__stats { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 768px) { .footer__grid { grid-template-columns: 1fr; } .footer__bottom { flex-direction: column; gap: 12px; align-items: flex-start; } }
</style>

<header class="header" id="header">
  <div class="header__inner">
    <a href="/zh/" class="header__logo">A.</a>
    <div class="header__right">
      <div class="header__lang">
        <a href="/ko/">KR</a>
        <a href="/">EN</a>
        <a href="/ja/">JP</a>
        <a href="/zh/" class="is-active">CN</a>
      </div>
      <a href="#contact" class="header__cta">联系我们</a>
    </div>
  </div>
</header>

<section class="hero">
  <h1 class="hero__title reveal">APL Color<br>专业培训</h1>
  <p class="hero__definition reveal reveal--d1">
    APL是韩国釜山的专业个人色彩培训项目。
    由持有<strong>国家认证色彩师技师</strong>资格的讲师运营，
    在<strong>釜山、首尔、大阪、上海</strong>4个城市设有工作室。
    使用LS170分光测色仪LAB色空间测色诊断和13,000多件诊断数据，
    提供科学的个人色彩分析和专家认证。
  </p>
</section>

<section class="section" id="about">
  <div class="container">
    <div class="section__eyebrow reveal"><span>01 — 介绍</span><span class="section__eyebrow-line"></span></div>
    <div class="about__grid">
      <div><h2 class="about__mission reveal reveal--d1">从身份认同<br>到品牌,<br>以及更远</h2></div>
      <div>
        <p class="about__desc reveal reveal--d2">
          APL Color从内在身份认同出发设计形象，构建个人和企业品牌的首尔法人。
          运营整合九型人格、色彩心理学、个人色彩分析和造型的综合系统，
          将专家培养和系统扩展延伸到4个国家。
        </p>
        <div class="about__stats reveal reveal--d2">
          <div class="stat"><div class="stat__num">4</div><div class="stat__label">Studios</div><div class="stat__sub">釜山 · 首尔<br>大阪 · 上海</div></div>
          <div class="stat"><div class="stat__num">13K+</div><div class="stat__label">Data</div><div class="stat__sub">诊断数据</div></div>
          <div class="stat"><div class="stat__num">4</div><div class="stat__label">Languages</div><div class="stat__sub">KR · EN · JP · CN</div></div>
          <div class="stat"><div class="stat__num">2024</div><div class="stat__label">Founded</div><div class="stat__sub">韩国法人</div></div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section" id="faq" style="background: var(--bg-white);">
  <div class="container">
    <div class="section__eyebrow reveal"><span>02 — FAQ</span><span class="section__eyebrow-line"></span></div>
    <h2 class="section__title reveal reveal--d1">常见问题</h2>
    <div class="faq__list reveal reveal--d2">
      <div class="faq__item">
        <button class="faq__q">APL的诊断与其他有何不同？<span class="faq__icon">+</span></button>
        <div class="faq__a"><div class="faq__a-inner">APL使用LS170分光测色仪进行LAB色空间测色诊断。不仅依靠主观的披肩法，还基于13,000多件科学数据提供客观诊断。</div></div>
      </div>
      <div class="faq__item">
        <button class="faq__q">在韩国以外也能接受服务吗？<span class="faq__icon">+</span></button>
        <div class="faq__a"><div class="faq__a-inner">是的。我们在釜山、首尔、大阪、上海4个城市运营工作室，提供韩语、英语、日语、中文4种语言的服务。</div></div>
      </div>
      <div class="faq__item">
        <button class="faq__q">参加专业课程需要什么前提条件？<span class="faq__icon">+</span></button>
        <div class="faq__a"><div class="faq__a-inner">无需前提条件。4天的集中课程面向初学者和有经验的专业人士。由持有国家认证色彩师技师资格的讲师亲自授课。</div></div>
      </div>
    </div>
  </div>
</section>

<footer class="footer" id="contact">
  <div class="container">
    <div class="footer__grid">
      <div>
        <div class="footer__brand">APL Color</div>
        <div class="footer__slogan">从身份认同到品牌，<br>以及更远。</div>
      </div>
      <div>
        <div class="footer__col-title">联系方式</div>
        <div class="footer__links">
          <a class="footer__link" href="mailto:contact@apls.co">contact@apls.co</a>
          <a class="footer__link" href="https://www.instagram.com/aplcolor_official/" target="_blank" rel="noopener">Instagram</a>
        </div>
      </div>
      <div>
        <div class="footer__col-title">品牌</div>
        <div class="footer__links">
          <a class="footer__link" href="#">APLCOLOR</a>
          <a class="footer__link" href="https://kcfb.kr" target="_blank" rel="noopener">KCFB</a>
        </div>
      </div>
    </div>
    <div class="footer__bottom">
      <div class="footer__legal">APLs Co., Ltd. · 首尔特别市江南区宣陵路428, 11F · CEO 林京恩</div>
      <div class="footer__lang">
        <a href="/ko/">KR</a>
        <a href="/">EN</a>
        <a href="/ja/">JP</a>
        <a href="/zh/" class="is-active">CN</a>
      </div>
    </div>
  </div>
</footer>

<script>
(function () {
  'use strict';
  const header = document.getElementById('header');
  window.addEventListener('scroll', () => { header?.classList.toggle('header--scrolled', window.scrollY > 40); }, { passive: true });
  const obs = new IntersectionObserver((entries) => { entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('is-visible'); obs.unobserve(e.target); } }); }, { threshold: 0.12 });
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
  document.querySelectorAll('.faq__q').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq__item'); const a = item?.querySelector('.faq__a') as HTMLElement | null; if (!item || !a) return;
      const open = item.classList.contains('is-open');
      document.querySelectorAll('.faq__item.is-open').forEach(o => { if (o !== item) { o.classList.remove('is-open'); const oa = o.querySelector('.faq__a') as HTMLElement | null; if (oa) oa.style.maxHeight = '0'; } });
      if (open) { item.classList.remove('is-open'); a.style.maxHeight = '0'; } else { item.classList.add('is-open'); a.style.maxHeight = a.scrollHeight + 'px'; }
    });
  });
})();
</script>

</BaseLayout>
