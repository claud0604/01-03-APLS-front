---
import BaseLayout from '../../layouts/BaseLayout.astro';

const alternates = [
  { lang: 'en', href: 'https://apls.kr/professional-course' },
  { lang: 'ko', href: 'https://apls.kr/ko/professional-course' },
  { lang: 'ja', href: 'https://apls.kr/ja/professional-course' },
  { lang: 'zh', href: 'https://apls.kr/zh/professional-course' },
];

const courseSchema = {
  "@context": "https://schema.org",
  "@type": "Course",
  "name": "APLパーソナルカラー専門家資格コース",
  "description": "国家公認カラーリスト技師講師陣による4日間集中パーソナルカラー専門家資格コース。LS170分光測色計LAB測色診断、ドレーピング技法、開業実務を含む。",
  "provider": { "@type": "Organization", "name": "APL Color", "url": "https://apls.kr" },
  "offers": { "@type": "Offer", "price": "4500000", "priceCurrency": "KRW" },
  "hasCourseInstance": { "@type": "CourseInstance", "courseMode": "Onsite", "courseWorkload": "P4D", "inLanguage": ["ko","en","ja","zh"] },
  "educationalCredentialAwarded": "KCFB認定パーソナルカラーアナリスト"
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "事前資格は必要ですか？", "acceptedAnswer": { "@type": "Answer", "text": "事前資格や経験は不要です。初心者から経験豊富な専門家まで、どなたでも受講いただけます。国家公認カラーリスト技師資格保有の講師が直接指導します。" } },
    { "@type": "Question", "name": "修了後どのような資格が得られますか？", "acceptedAnswer": { "@type": "Answer", "text": "KCFB（韓国パーソナルカラーファッションビューティー協会）認定パーソナルカラーアナリスト資格と固有の資格番号が発行されます。韓国・日本・中国のAPLネットワークで認められます。" } },
    { "@type": "Question", "name": "APLの診断方法は何が違いますか？", "acceptedAnswer": { "@type": "Answer", "text": "APLはLS170分光測色計によるLAB色空間測色診断を併用します。主観的なドレーピングだけでなく、機器測定＋視覚評価のデュアルアプローチで客観的な診断を提供します。" } }
  ]
};

const schemas = [courseSchema, faqSchema];
---

<BaseLayout
  title="パーソナルカラー専門家資格コース — 4日間集中認定 | APL Color"
  description="国家公認カラーリスト技師講師陣による4日間集中パーソナルカラー専門家資格コース。LS170分光測色計LAB診断、KCFB認定資格。釜山・ソウル・大阪・上海。"
  lang="ja"
  alternates={alternates}
  schema={schemas}
>

<style>
:root {
  --bg: #ece0c8; --bg-white: #FFFFFF; --text: #222222; --text-sub: #888888; --text-dim: #AAAAAA; --border: #E5E5E5;
  --font: "Inter", "Noto Sans KR", -apple-system, BlinkMacSystemFont, sans-serif;
  --header-h: 54px; --pad: clamp(20px, 4vw, 52px); --max-w: 1080px;
  --ease: cubic-bezier(.165, .84, .44, 1); --dur-fast: 0.3s;
}
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { font-size: 16px; -webkit-font-smoothing: antialiased; scroll-behavior: smooth; }
body { font-family: var(--font); color: var(--text); background: var(--bg); line-height: 1.5; overflow-x: hidden; }
a { color: inherit; text-decoration: none; }
button { font: inherit; cursor: pointer; border: none; background: none; }

.header { position: fixed; top: 0; left: 0; right: 0; z-index: 100; height: var(--header-h); display: flex; align-items: center; background: rgba(236, 224, 200, 0.92); backdrop-filter: blur(16px); border-bottom: 1px solid var(--border); }
.header__inner { width: 100%; max-width: 1816px; margin: 0 auto; padding: 0 var(--pad); display: flex; align-items: center; justify-content: space-between; }
.header__logo { font-weight: 800; font-size: 18px; }
.header__right { display: flex; align-items: center; gap: 20px; }
.header__lang { display: flex; gap: 6px; font-size: 12px; font-weight: 500; }
.header__lang a { color: var(--text-dim); transition: color var(--dur-fast); }
.header__lang a.is-active { color: var(--text); }
.header__cta { font-size: 12px; font-weight: 600; padding: 8px 18px; border: 1.5px solid var(--text); border-radius: 2px; transition: background var(--dur-fast), color var(--dur-fast); }
.header__cta:hover { background: var(--text); color: var(--bg); }

.breadcrumb { padding: calc(var(--header-h) + 24px) var(--pad) 0; max-width: var(--max-w); margin: 0 auto; font-size: 12px; color: var(--text-dim); }
.page { max-width: var(--max-w); margin: 0 auto; padding: 48px var(--pad) 120px; }
.page__eyebrow { font-weight: 600; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-dim); margin-bottom: 16px; }
.page__title { font-weight: 800; font-size: clamp(32px, 5vw, 56px); line-height: 1.05; letter-spacing: -0.03em; margin-bottom: 32px; }
.page__definition { font-size: clamp(16px, 1.3vw, 19px); line-height: 1.75; color: var(--text-sub); margin-bottom: 64px; max-width: 720px; }
.page__definition strong { color: var(--text); }

.section-block { margin-bottom: 64px; }
.section-block__title { font-weight: 700; font-size: 14px; letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 20px; padding-bottom: 12px; border-bottom: 1px solid var(--border); }

.spec table { width: 100%; border-collapse: collapse; }
.spec th, .spec td { text-align: left; padding: 14px 16px; font-size: 14px; border-bottom: 1px solid var(--border); }
.spec th { font-weight: 600; font-size: 12px; color: var(--text-dim); width: 140px; background: var(--bg-white); }

.curriculum__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.curriculum__day { padding: 24px; background: var(--bg-white); border: 1px solid var(--border); }
.curriculum__day-num { font-weight: 700; font-size: 11px; letter-spacing: 0.1em; color: var(--text-dim); margin-bottom: 8px; }
.curriculum__day-title { font-weight: 700; font-size: 16px; margin-bottom: 10px; }
.curriculum__day-list { font-size: 13px; line-height: 1.7; color: var(--text-sub); }

.faq__item { border-bottom: 1px solid var(--border); }
.faq__q { width: 100%; display: flex; justify-content: space-between; align-items: center; padding: 18px 0; font-weight: 600; font-size: 15px; text-align: left; }
.faq__q:hover { opacity: 0.5; }
.faq__icon { font-size: 18px; font-weight: 300; flex-shrink: 0; margin-left: 16px; transition: transform var(--dur-fast) var(--ease); }
.faq__item.is-open .faq__icon { transform: rotate(45deg); }
.faq__a { max-height: 0; overflow: hidden; transition: max-height 0.6s var(--ease); }
.faq__a-inner { padding-bottom: 18px; font-size: 14px; line-height: 1.7; color: var(--text-sub); }

.cta-block { text-align: center; padding: 64px 0; border-top: 1px solid var(--border); }
.cta-block__title { font-weight: 800; font-size: clamp(22px, 3vw, 36px); margin-bottom: 12px; }
.cta-block__sub { font-size: 14px; color: var(--text-sub); margin-bottom: 28px; }
.cta-block__btn { display: inline-flex; font-weight: 600; font-size: 13px; padding: 14px 32px; background: var(--text); color: var(--bg); border-radius: 2px; transition: opacity var(--dur-fast); }
.cta-block__btn:hover { opacity: 0.8; }

.footer { border-top: 1px solid var(--border); padding: 48px 0; }
.footer__inner { max-width: 1816px; margin: 0 auto; padding: 0 var(--pad); display: flex; justify-content: space-between; align-items: center; }
.footer__legal { font-size: 11px; color: var(--text-dim); }
.footer__lang { display: flex; gap: 10px; }
.footer__lang a { font-size: 11px; font-weight: 600; color: var(--text-dim); }
.footer__lang a.is-active { color: var(--text); }

@media (max-width: 768px) { .curriculum__grid { grid-template-columns: 1fr; } .footer__inner { flex-direction: column; gap: 12px; align-items: flex-start; } }
</style>

<header class="header">
  <div class="header__inner">
    <a href="/ja/" class="header__logo">A.</a>
    <div class="header__right">
      <div class="header__lang">
        <a href="/ko/professional-course">KR</a>
        <a href="/professional-course">EN</a>
        <a href="/ja/professional-course" class="is-active">JP</a>
        <a href="/zh/professional-course">CN</a>
      </div>
      <a href="#enroll" class="header__cta">お申し込み</a>
    </div>
  </div>
</header>

<nav class="breadcrumb"><a href="/ja/">ホーム</a> / <strong>専門家コース</strong></nav>

<article class="page">
  <div class="page__eyebrow">KCFB認定プログラム</div>
  <h1 class="page__title">パーソナルカラー<br>専門家資格コース</h1>

  <p class="page__definition">
    APLは韓国釜山を拠点とするパーソナルカラー専門家養成プログラムです。
    <strong>国家公認カラーリスト技師</strong>資格保有の講師陣が運営し、
    <strong>釜山、ソウル、大阪、上海</strong>にスタジオを展開。
    4日間の集中資格コースは<strong>LS170分光測色計によるLAB測色診断</strong>と
    ドレーピング技法を組み合わせ、<strong>13,000件以上の診断データ</strong>に基づいて
    科学的パーソナルカラーアナリストを養成します。
  </p>

  <section class="section-block spec">
    <h2 class="section-block__title">コース詳細</h2>
    <table>
      <tr><th>期間</th><td>4日間集中コース</td></tr>
      <tr><th>言語</th><td>韓国語 / 英語 / 日本語 / 中国語</td></tr>
      <tr><th>資格</th><td>KCFB認定パーソナルカラーアナリスト（固有資格番号発行）</td></tr>
      <tr><th>受講料</th><td>₩4,500,000（約50万円）</td></tr>
      <tr><th>定員</th><td>少人数制（1回最大6名、実習中心）</td></tr>
      <tr><th>会場</th><td>釜山・ソウル（韓国）/ 大阪（日本）/ 上海（中国）</td></tr>
      <tr><th>前提条件</th><td>なし — 初心者・経験者ともに受講可能</td></tr>
    </table>
  </section>

  <section class="section-block">
    <h2 class="section-block__title">4日間カリキュラム</h2>
    <div class="curriculum__grid">
      <div class="curriculum__day"><div class="curriculum__day-num">Day 01</div><h3 class="curriculum__day-title">色彩科学基礎</h3><p class="curriculum__day-list">色彩理論 & LAB色空間 · 光と肌のアンダートーン · マンセル & シーズンカラー · LS170入門</p></div>
      <div class="curriculum__day"><div class="curriculum__day-num">Day 02</div><h3 class="curriculum__day-title">診断方法論</h3><p class="curriculum__day-list">LS170 LAB測定実習 · ドレーピング技法基礎 · 14シーズン分類体系 · ライブモデル実習</p></div>
      <div class="curriculum__day"><div class="curriculum__day-num">Day 03</div><h3 class="curriculum__day-title">応用実践</h3><p class="curriculum__day-list">顔型 & 体型分析 · スタイリング統合 · クライアント相談フロー · ケーススタディ</p></div>
      <div class="curriculum__day"><div class="curriculum__day-num">Day 04</div><h3 class="curriculum__day-title">資格認定 & 開業</h3><p class="curriculum__day-list">実技資格試験 · 開業実務 & 価格戦略 · KCFBネットワーク · 修了証授与</p></div>
    </div>
  </section>

  <section class="section-block">
    <h2 class="section-block__title">よくある質問</h2>
    <div class="faq__item"><button class="faq__q">事前資格は必要ですか？<span class="faq__icon">+</span></button><div class="faq__a"><div class="faq__a-inner">事前資格や経験は不要です。初心者から経験豊富な専門家まで受講いただけます。国家公認カラーリスト技師資格保有の講師が直接指導します。</div></div></div>
    <div class="faq__item"><button class="faq__q">修了後どのような資格が得られますか？<span class="faq__icon">+</span></button><div class="faq__a"><div class="faq__a-inner">KCFB認定パーソナルカラーアナリスト資格と固有の資格番号が発行されます。韓国・日本・中国のAPLネットワークで認められます。</div></div></div>
    <div class="faq__item"><button class="faq__q">APLの診断方法は何が違いますか？<span class="faq__icon">+</span></button><div class="faq__a"><div class="faq__a-inner">LS170分光測色計によるLAB色空間測色診断を併用。主観的ドレーピングだけでなく、機器測定＋視覚評価のデュアルアプローチで客観的診断を提供します。</div></div></div>
  </section>

  <section class="cta-block" id="enroll">
    <h2 class="cta-block__title">パーソナルカラーの<br>プロになりましょう</h2>
    <p class="cta-block__sub">日程の確認・受講予約はお問い合わせください。</p>
    <a href="mailto:contact@apls.co" class="cta-block__btn">受講お問い合わせ →</a>
  </section>
</article>

<footer class="footer">
  <div class="footer__inner">
    <div class="footer__legal">APLs Co., Ltd. · ソウル特別市江南区宣陵路428, 11F · CEO 林京恩</div>
    <div class="footer__lang"><a href="/ko/professional-course">KR</a><a href="/professional-course">EN</a><a href="/ja/professional-course" class="is-active">JP</a><a href="/zh/professional-course">CN</a></div>
  </div>
</footer>

<script>
(function(){document.querySelectorAll('.faq__q').forEach(btn=>{btn.addEventListener('click',()=>{const item=btn.closest('.faq__item');const a=item?.querySelector('.faq__a') as HTMLElement|null;if(!item||!a)return;const open=item.classList.contains('is-open');document.querySelectorAll('.faq__item.is-open').forEach(o=>{if(o!==item){o.classList.remove('is-open');const oa=o.querySelector('.faq__a') as HTMLElement|null;if(oa)oa.style.maxHeight='0';}});if(open){item.classList.remove('is-open');a.style.maxHeight='0';}else{item.classList.add('is-open');a.style.maxHeight=a.scrollHeight+'px';}});});})();
</script>

</BaseLayout>
