---
import BaseLayout from '../layouts/BaseLayout.astro';

const alternates = [
  { lang: 'en', href: 'https://apls.kr/' },
  { lang: 'ko', href: 'https://apls.kr/ko/' },
  { lang: 'ja', href: 'https://apls.kr/ja/' },
  { lang: 'zh', href: 'https://apls.kr/zh/' },
];

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "APL Color",
  "alternateName": ["APLs", "APLCOLOR", "에이피엘컬러"],
  "url": "https://apls.kr",
  "logo": "https://apls.kr/images/APLCOLOR_logo_nobg.png",
  "description": "Professional personal color analysis & training company based in Busan, Korea. Operated by nationally certified Colorist Engineers, with studios in Busan, Seoul, Osaka, and Shanghai.",
  "foundingDate": "2024",
  "founder": {
    "@type": "Person",
    "name": "Kyungeun Lim",
    "alternateName": "임경은"
  },
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "선릉로 428, 11층",
    "addressLocality": "Seoul",
    "addressRegion": "Gangnam-gu",
    "addressCountry": "KR"
  },
  "sameAs": [
    "https://www.instagram.com/aplcolor_official/",
    "https://kcfb.kr"
  ],
  "areaServed": [
    { "@type": "City", "name": "Busan" },
    { "@type": "City", "name": "Seoul" },
    { "@type": "City", "name": "Osaka" },
    { "@type": "City", "name": "Shanghai" }
  ],
  "knowsLanguage": ["ko", "en", "ja", "zh"]
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "APL Color",
  "url": "https://apls.kr",
  "inLanguage": ["en", "ko", "ja", "zh"]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is APL Color?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "APL Color is a professional personal color analysis and branding company headquartered in Seoul, Korea. We specialize in personal color diagnosis using LS170 spectrophotometer LAB colorimetry, with studios in Busan, Seoul, Osaka, and Shanghai."
      }
    },
    {
      "@type": "Question",
      "name": "Do I need prior qualifications to take the professional course?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No prior qualifications are required. Our 4-day intensive professional course is designed for both beginners and experienced professionals. The course is taught by nationally certified Korea National Colorist Engineers."
      }
    },
    {
      "@type": "Question",
      "name": "What makes APL different from other personal color programs?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "APL uses LS170 spectrophotometer-based LAB colorimetry instead of subjective draping alone. Our instructors hold Korea National Colorist Engineer certifications, and we operate across 4 countries (Korea, Japan, China) with 13,000+ diagnosis data points."
      }
    },
    {
      "@type": "Question",
      "name": "Is the service available outside Korea?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. We operate studios in Busan, Seoul, Osaka, and Shanghai, providing services in Korean, English, Japanese, and Chinese."
      }
    },
    {
      "@type": "Question",
      "name": "What is the relationship between APLs and APLCOLOR?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "APLs is the parent corporation, while APLCOLOR is the B2C personal color diagnosis studio sub-brand serving individual clients."
      }
    }
  ]
};

const schemas = [organizationSchema, websiteSchema, faqSchema];
---

<BaseLayout
  title="APL Color — Professional Personal Color Analysis & Training | Korea"
  description="APL Color is a professional personal color training program in Busan, Korea. Operated by nationally certified Colorist Engineers with LS170 LAB colorimetry. Studios in Busan, Seoul, Osaka, Shanghai."
  lang="en"
  alternates={alternates}
  schema={schemas}
>

<style>
/* ═══════════════════════════════════════════════════════════
   TOKENS
   ═══════════════════════════════════════════════════════════ */
:root {
  --bg:       #ece0c8;
  --bg-white: #FFFFFF;
  --text:     #222222;
  --text-sub: #888888;
  --text-dim: #AAAAAA;
  --border:   #E5E5E5;
  --accent:   #FA5D29;

  --font: "Inter", "Noto Sans KR", -apple-system, BlinkMacSystemFont, sans-serif;
  --font-serif: "Cormorant Garamond", Georgia, serif;

  --header-h: 54px;
  --pad: clamp(20px, 4vw, 52px);
  --max-w: 1816px;

  --ease: cubic-bezier(.165, .84, .44, 1);
  --dur: 0.5s;
  --dur-fast: 0.3s;
}

/* ═══════════════════════════════════════════════════════════
   RESET
   ═══════════════════════════════════════════════════════════ */
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { font-size: 16px; -webkit-font-smoothing: antialiased; scroll-behavior: smooth; }
body { font-family: var(--font); font-weight: 400; color: var(--text); background: var(--bg); line-height: 1.5; overflow-x: hidden; }
a { color: inherit; text-decoration: none; }
button { font: inherit; cursor: pointer; border: none; background: none; }
img, video { display: block; max-width: 100%; }
ul, ol { list-style: none; }

/* ═══════════════════════════════════════════════════════════
   HEADER
   ═══════════════════════════════════════════════════════════ */
.header {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  height: var(--header-h);
  display: flex;
  align-items: center;
  background: transparent;
  transition: background var(--dur) var(--ease);
}

.header--scrolled {
  background: rgba(236, 224, 200, 0.92);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--border);
}

.header__inner {
  width: 100%;
  max-width: var(--max-w);
  margin: 0 auto;
  padding: 0 var(--pad);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.header__logo {
  font-weight: 800;
  font-size: 18px;
  letter-spacing: 0.02em;
}

.header__nav {
  display: flex;
  align-items: center;
  gap: 28px;
}

.header__nav a {
  font-weight: 500;
  font-size: 13px;
  letter-spacing: 0.02em;
  transition: opacity var(--dur-fast) var(--ease);
}

.header__nav a:hover { opacity: 0.5; }

.header__right {
  display: flex;
  align-items: center;
  gap: 20px;
}

.header__lang {
  display: flex;
  gap: 6px;
  font-size: 12px;
  font-weight: 500;
}

.header__lang a { color: var(--text-dim); transition: color var(--dur-fast); }
.header__lang a.is-active { color: var(--text); }
.header__lang a:hover { color: var(--text); }

.header__cta {
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.04em;
  padding: 8px 18px;
  border: 1.5px solid var(--text);
  border-radius: 2px;
  transition: background var(--dur-fast), color var(--dur-fast);
}

.header__cta:hover { background: var(--text); color: var(--bg); }

.header__menu-btn {
  display: none;
  flex-direction: column;
  gap: 5px;
  width: 22px;
}

.header__menu-btn span {
  display: block;
  height: 1.5px;
  background: var(--text);
}

/* ═══════════════════════════════════════════════════════════
   HERO
   ═══════════════════════════════════════════════════════════ */
.hero {
  position: relative;
  min-height: auto;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: calc(var(--header-h) + 100px) var(--pad) 0;
  overflow: hidden;
}

.hero-toolbar {
  position: absolute;
  top: calc(var(--header-h) + 24px);
  left: var(--pad);
  right: var(--pad);
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 2;
}

.hero-toolbar__left { display: flex; align-items: center; }

.box-score {
  display: flex;
  align-items: center;
  gap: 12px;
  border: 1px solid var(--border);
  border-radius: 2px;
  padding: 8px 16px;
  background: rgba(236, 224, 200, 0.6);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.box-score__top strong {
  font-weight: 700;
  font-size: 10px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--text-dim);
}

.box-score__bottom {
  display: flex;
  align-items: baseline;
  gap: 3px;
}

.box-score__bottom strong {
  font-weight: 800;
  font-size: 16px;
  letter-spacing: -0.02em;
  color: var(--text);
}

.box-score__bottom sub {
  font-size: 10px;
  font-weight: 500;
  color: var(--text-dim);
  letter-spacing: 0.02em;
}

.hero-toolbar__right { display: flex; align-items: center; }

.toolbar-bts {
  display: flex;
  align-items: center;
  gap: 0;
}

.toolbar-bts li { display: flex; }

.toolbar-bts__item {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border: 1px solid var(--border);
  margin-left: -1px;
  color: var(--text);
  transition: background var(--dur-fast) var(--ease), color var(--dur-fast);
  background: rgba(236, 224, 200, 0.6);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.toolbar-bts li:first-child .toolbar-bts__item { border-radius: 2px 0 0 2px; margin-left: 0; }
.toolbar-bts li:last-child .toolbar-bts__item { border-radius: 0 2px 2px 0; }

.toolbar-bts__item:hover {
  background: var(--text);
  color: var(--bg);
}

.hero__title {
  font-weight: 500;
  font-size: clamp(38px, 8.8vw, 160px);
  line-height: 0.9;
  letter-spacing: -0.04em;
  text-transform: uppercase;
  padding-bottom: clamp(32px, 4vw, 60px);
  position: relative;
  z-index: 2;
}

/* GEO: Definition statement - visible to crawlers */
.hero__definition {
  font-size: clamp(15px, 1.2vw, 18px);
  line-height: 1.7;
  color: var(--text-sub);
  max-width: 720px;
  padding: 0 var(--pad) clamp(40px, 6vw, 80px);
}

/* ═══════════════════════════════════════════════════════════
   SECTION COMMON
   ═══════════════════════════════════════════════════════════ */
.section {
  padding: clamp(60px, 10vw, 160px) 0;
}

.container {
  width: 100%;
  max-width: var(--max-w);
  margin: 0 auto;
  padding: 0 var(--pad);
}

.section__eyebrow {
  font-weight: 500;
  font-size: 11px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--text-dim);
  margin-bottom: 32px;
  display: flex;
  align-items: center;
  gap: 16px;
}

.section__eyebrow-line {
  flex: 1;
  height: 1px;
  background: var(--border);
}

.section__title {
  font-weight: 800;
  font-size: clamp(28px, 4.5vw, 64px);
  line-height: 1.05;
  letter-spacing: -0.03em;
  margin-bottom: clamp(32px, 4vw, 64px);
}

/* ═══════════════════════════════════════════════════════════
   ABOUT
   ═══════════════════════════════════════════════════════════ */
.about__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(40px, 6vw, 120px);
  align-items: start;
}

.about__mission {
  font-weight: 700;
  font-size: clamp(24px, 3.5vw, 52px);
  line-height: 1.1;
  letter-spacing: -0.02em;
}

.about__desc {
  font-size: clamp(14px, 1.1vw, 17px);
  line-height: 1.75;
  color: var(--text-sub);
  margin-bottom: 48px;
}

.about__stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
  padding-top: 40px;
  border-top: 1px solid var(--border);
}

.stat__num {
  font-weight: 800;
  font-size: clamp(24px, 2.5vw, 42px);
  letter-spacing: -0.02em;
  line-height: 1;
  margin-bottom: 6px;
}

.stat__label {
  font-weight: 600;
  font-size: 10px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-dim);
  margin-bottom: 2px;
}

.stat__sub {
  font-size: 11px;
  color: var(--text-dim);
  line-height: 1.4;
}

/* ═══════════════════════════════════════════════════════════
   OUR SYSTEM
   ═══════════════════════════════════════════════════════════ */
.system__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1px;
  background: var(--border);
}

.system__card {
  background: var(--bg);
  padding: clamp(24px, 2.5vw, 44px);
  display: flex;
  flex-direction: column;
  min-height: 300px;
  transition: background var(--dur-fast) var(--ease);
}

.system__card:hover { background: var(--bg-white); }

.system__card-num {
  font-weight: 600;
  font-size: 10px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--text-dim);
  margin-bottom: 40px;
}

.system__card-title {
  font-weight: 800;
  font-size: clamp(18px, 1.8vw, 28px);
  letter-spacing: -0.01em;
  text-transform: uppercase;
  margin-bottom: 12px;
  line-height: 1.15;
}

.system__card-tags {
  font-size: 12px;
  color: var(--text-sub);
  line-height: 1.7;
  margin-bottom: auto;
}

.system__card-arrow {
  font-size: 22px;
  color: var(--text-dim);
  margin-top: 20px;
  transition: transform var(--dur-fast) var(--ease), color var(--dur-fast);
}

.system__card:hover .system__card-arrow {
  transform: translateX(4px);
  color: var(--text);
}

/* ═══════════════════════════════════════════════════════════
   SERVICES
   ═══════════════════════════════════════════════════════════ */
.services__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--border);
}

.service {
  background: var(--bg-white);
  padding: clamp(24px, 2.5vw, 44px);
  display: flex;
  flex-direction: column;
  min-height: 260px;
  transition: background var(--dur-fast) var(--ease);
}

.service:hover { background: #fff; }

.service__tag {
  font-weight: 600;
  font-size: 10px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-dim);
  margin-bottom: 20px;
}

.service__name {
  font-weight: 700;
  font-size: clamp(16px, 1.5vw, 24px);
  margin-bottom: 10px;
}

.service__desc {
  font-size: 13px;
  line-height: 1.65;
  color: var(--text-sub);
  margin-bottom: auto;
}

.service__link {
  font-weight: 600;
  font-size: 11px;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  margin-top: 20px;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  transition: gap var(--dur-fast);
}

.service:hover .service__link { gap: 10px; }

/* ═══════════════════════════════════════════════════════════
   PROGRAMS
   ═══════════════════════════════════════════════════════════ */
.programs__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

.program {
  border: 1px solid var(--border);
  transition: border-color var(--dur-fast);
}

.program:hover { border-color: var(--text); }

.program__img {
  aspect-ratio: 4/3;
  overflow: hidden;
  background: repeating-linear-gradient(135deg, #ddd 0 1px, transparent 1px 12px), #eee;
  display: flex;
  align-items: center;
  justify-content: center;
}

.program__img span {
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #bbb;
}

.program__body { padding: clamp(16px, 2vw, 28px); }

.program__tag {
  font-weight: 600;
  font-size: 10px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
  margin-bottom: 10px;
}

.program__name {
  font-weight: 700;
  font-size: clamp(16px, 1.4vw, 22px);
  margin-bottom: 8px;
}

.program__desc {
  font-size: 13px;
  line-height: 1.6;
  color: var(--text-sub);
}

/* ═══════════════════════════════════════════════════════════
   EXPERTS
   ═══════════════════════════════════════════════════════════ */
.experts__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
}

.expert { text-align: center; }

.expert__photo {
  aspect-ratio: 3/4;
  overflow: hidden;
  margin-bottom: 14px;
  background: repeating-linear-gradient(135deg, #ddd 0 1px, transparent 1px 12px), #eee;
  filter: grayscale(100%);
  transition: filter 0.6s var(--ease);
  display: flex;
  align-items: center;
  justify-content: center;
}

.expert:hover .expert__photo { filter: grayscale(0%); }

.expert__photo span {
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #bbb;
}

.expert__name { font-weight: 600; font-size: 14px; margin-bottom: 2px; }
.expert__role { font-size: 11px; color: var(--text-dim); }

/* ═══════════════════════════════════════════════════════════
   COMMUNITY
   ═══════════════════════════════════════════════════════════ */
.community {
  background: var(--text);
  color: #fff;
  text-align: center;
  padding: clamp(80px, 12vw, 200px) var(--pad);
}

.community__eyebrow {
  font-weight: 600;
  font-size: 11px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.3);
  margin-bottom: 28px;
}

.community__title {
  font-weight: 800;
  font-size: clamp(28px, 5vw, 72px);
  line-height: 1;
  letter-spacing: -0.03em;
  text-transform: uppercase;
  margin-bottom: 20px;
}

.community__sub {
  font-size: clamp(13px, 1vw, 16px);
  line-height: 1.65;
  color: rgba(255,255,255,0.5);
  max-width: 520px;
  margin: 0 auto 48px;
}

.community__benefits {
  display: flex;
  justify-content: center;
  gap: 64px;
  margin-bottom: 48px;
}

.benefit { max-width: 220px; }
.benefit__num { font-weight: 600; font-size: 10px; letter-spacing: 0.12em; color: rgba(255,255,255,0.25); margin-bottom: 10px; }
.benefit__title { font-weight: 600; font-size: 15px; margin-bottom: 6px; }
.benefit__desc { font-size: 12px; line-height: 1.55; color: rgba(255,255,255,0.45); }

.btn {
  display: inline-flex;
  align-items: center;
  font-weight: 600;
  font-size: 12px;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: 12px 28px;
  border: 1.5px solid;
  border-radius: 2px;
  transition: background var(--dur-fast), color var(--dur-fast);
}

.btn--light { border-color: #fff; color: #fff; }
.btn--light:hover { background: #fff; color: var(--text); }

/* ═══════════════════════════════════════════════════════════
   TESTIMONIALS
   ═══════════════════════════════════════════════════════════ */
.testimonials__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--border);
}

.testimonial {
  background: var(--bg);
  padding: clamp(24px, 2.5vw, 44px);
  display: flex;
  flex-direction: column;
}

.testimonial__quote {
  font-size: clamp(14px, 1.1vw, 17px);
  line-height: 1.7;
  color: var(--text-sub);
  margin-bottom: auto;
  padding-bottom: 32px;
}

.testimonial__quote::before {
  content: '\201C';
  display: block;
  font-weight: 300;
  font-size: 40px;
  line-height: 1;
  color: var(--border);
  margin-bottom: 12px;
}

.testimonial__author { font-weight: 600; font-size: 13px; margin-bottom: 2px; }
.testimonial__role { font-size: 11px; color: var(--text-dim); }

/* ═══════════════════════════════════════════════════════════
   FAQ
   ═══════════════════════════════════════════════════════════ */
.faq__list { max-width: 760px; }

.faq__item { border-bottom: 1px solid var(--border); }

.faq__q {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px 0;
  font-weight: 600;
  font-size: clamp(14px, 1.1vw, 17px);
  text-align: left;
  transition: opacity var(--dur-fast);
}

.faq__q:hover { opacity: 0.5; }

.faq__icon {
  font-size: 18px;
  font-weight: 300;
  flex-shrink: 0;
  margin-left: 20px;
  transition: transform var(--dur-fast) var(--ease);
}

.faq__item.is-open .faq__icon { transform: rotate(45deg); }

.faq__a {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.6s var(--ease);
}

.faq__a-inner {
  padding-bottom: 20px;
  font-size: 13px;
  line-height: 1.7;
  color: var(--text-sub);
  max-width: 600px;
}

/* ═══════════════════════════════════════════════════════════
   FOOTER
   ═══════════════════════════════════════════════════════════ */
.footer {
  border-top: 1px solid var(--border);
  padding: 64px 0 48px;
}

.footer__grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 48px;
  margin-bottom: 64px;
}

.footer__brand { font-weight: 800; font-size: 18px; letter-spacing: 0.02em; margin-bottom: 12px; }
.footer__slogan { font-size: 13px; line-height: 1.5; color: var(--text-sub); }

.footer__col-title {
  font-weight: 600;
  font-size: 10px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-dim);
  margin-bottom: 14px;
}

