---
interface Props {
  title: string;
  description: string;
  lang?: string;
  alternates?: { lang: string; href: string }[];
  ogImage?: string;
  canonicalURL?: string;
  schema?: object[];
}

const {
  title,
  description,
  lang = 'en',
  alternates = [],
  ogImage = '/images/APLCOLOR_logo_nobg.png',
  canonicalURL,
  schema = [],
} = Astro.props;

const siteURL = 'https://apls.kr';
const canonical = canonicalURL || new URL(Astro.url.pathname, siteURL).href;
const ogImageURL = new URL(ogImage, siteURL).href;
---

<!doctype html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <!-- Naver Search Advisor -->
  <meta name="naver-site-verification" content="09f9943515a647df521e4c7c162385e9504a09a1" />

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/images/APLCOLOR_logo_nobg.png" />
  <link rel="apple-touch-icon" href="/images/APLCOLOR_logo_nobg.png" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageURL} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="APL Color" />
  <meta property="og:locale" content={lang} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageURL} />

  <!-- hreflang -->
  {alternates.map((alt) => (
    <link rel="alternate" hreflang={alt.lang} href={alt.href} />
  ))}
  {alternates.length > 0 && (
    <link rel="alternate" hreflang="x-default" href={siteURL} />
  )}

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600;700;800;900&family=Noto+Sans+KR:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />

  <!-- JSON-LD Structured Data -->
  {schema.map((s) => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}
</head>
<body>
  <slot />
</body>
</html>
